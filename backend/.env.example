# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Connection URI
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database_name>

# JWT Authentication Configuration
JWT_SECRET=your_jwt_secret_key_minimum_8_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d
JWT_ACCESS_EXPIRES_IN=30m

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# SePay Integration Configuration
# API Key: SePay Dashboard → Tích hợp Webhooks → Authorization (kiểu Api Key)
SEPAY_WEBHOOK_API_KEY=your_sepay_webhook_api_key
# Tài khoản ngân hàng đã liên kết SePay
SEPAY_ACCOUNT_NUMBER=your_bank_account_number
# Mã ngân hàng theo SePay: MBBank, Vietcombank, ACB, TPBank, BIDV, Techcombank...
SEPAY_BANK_CODE=MBBank
SEPAY_ACCOUNT_NAME=YOUR ACCOUNT NAME

# Email — Gửi qua Brevo HTTP API (https://www.brevo.com), không bị Render chặn cổng SMTP.
# 1) Tạo API key tại Brevo Dashboard → SMTP & API → API Keys (dạng xkeysib-...)
# 2) Verify email người gửi tại Senders, Domains & Dedicated IPs → Senders
#    rồi đặt MAIL_FROM trùng đúng email đã verify đó.
BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxxxxxx
MAIL_FROM=LenFolk <your-verified-email@gmail.com>
# Hộp thư nhận phản hồi (nên có người đọc) — tăng độ tin cậy
MAIL_REPLY_TO=your-verified-email@gmail.com
APP_NAME=LenFolk
# URL frontend (dùng cho link trong email nếu cần)
CLIENT_URL=http://localhost:3000

# AI analysis
# Free users use Gemini; paid/subscribed users use OpenAI.
GEMINI_API_KEY=your_gemini_api_key
GEMINI_ANALYSIS_MODEL=gemini-2.5-flash
OPENAI_API_KEY=your_openai_api_key
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
OPENAI_ANALYSIS_MODEL=gpt-5.2
# Google OAuth — Đăng nhập bằng Google
# Lấy từ Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
# Client gửi idToken lên POST /api/auth/google; server xác minh với các client ID này.
GOOGLE_IOS_CLIENT_ID=
GOOGLE_WEB_CLIENT_ID=
GOOGLE_ANDROID_CLIENT_ID=