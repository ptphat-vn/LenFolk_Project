# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Connection URI
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database_name>

# JWT Authentication Configuration
JWT_SECRET=your_jwt_secret_key_minimum_8_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d
JWT_ACCESS_EXPIRES_IN=30m

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# SePay Integration Configuration
# API Key: SePay Dashboard → Tích hợp Webhooks → Authorization (kiểu Api Key)
SEPAY_WEBHOOK_API_KEY=your_sepay_webhook_api_key
# Tài khoản ngân hàng đã liên kết SePay
SEPAY_ACCOUNT_NUMBER=your_bank_account_number
# Mã ngân hàng theo SePay: MBBank, Vietcombank, ACB, TPBank, BIDV, Techcombank...
SEPAY_BANK_CODE=MBBank
SEPAY_ACCOUNT_NAME=YOUR ACCOUNT NAME

# Email (Nodemailer / SMTP) — vd dùng Gmail (cần App Password) hoặc Mailtrap/SendGrid
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=your_email@gmail.com
MAIL_PASS=your_app_password
MAIL_FROM=LenFolk <no-reply@lenfolk.com>
APP_NAME=LenFolk
# URL frontend (dùng cho link trong email nếu cần)
CLIENT_URL=http://localhost:3000
